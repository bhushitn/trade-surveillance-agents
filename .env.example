# Copy to .env and fill in values from your AWS account (docs/DEPLOYMENT.md).
# Every variable is optional: leave any of them unset and the matching service
# falls back to its documented local behavior, so the system runs fully offline.

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# Or, on an isolated dev desktop, authenticate with your usual SSO/credential
# tooling instead of static keys and leave the two keys above unset.
BEDROCK_MODEL_ID=claude-sonnet-4-6

# --- AgentCore Memory (per-case session, branch per agent) ---
# Unset: agent transcripts land in ${LOCAL_STATE_DIR}/memory/<case>/<agent>.jsonl
AGENTCORE_MEMORY_ID=REPLACE_ME

# --- AgentCore Gateway (MCP endpoint fronting the account/market APIs) ---
# Unset: agents call the in-process mock APIs directly.
AGENTCORE_GATEWAY_URL=https://REPLACE_ME.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp

# --- AgentCore Identity (OAuth2 M2M provider used for Gateway auth) ---
# Unset: no bearer token is attached (local mode only).
AGENTCORE_IDENTITY_PROVIDER=REPLACE_ME

# --- Observability ---
# Unset: tracing is a no-op. In AgentCore Runtime the ADOT sidecar sets this.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Local state ---
LOCAL_STATE_DIR=.local_state
